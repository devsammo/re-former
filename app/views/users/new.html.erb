<form 
	action="/users" 
	method="post" 
	accept-charset="UTF-8" 
	data-turbo=false
>
	<label for="username">
		username
		<input type="text" name="username">
	</label>
	<label for="email">
		email
		<input type="email" name="email">
	</label>
	<label for="password">
		password
		<input type="password" name="password">
	</label>
	<input
		type="hidden"
		name="authenticity_token"
		value="<%= form_authenticity_token %>"
	>
	<button type="submit">create user</button>
</form>